{
    "info": {
        "name": "FriendLens Backend API",
        "description": "API endpoints for the FriendLens backend running on Render.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "base_url",
            "value": "https://friendlens-backend.onrender.com",
            "type": "string"
        },
        {
            "key": "auth_token",
            "value": "YOUR_SUPABASE_JWT_TOKEN_HERE",
            "type": "string"
        },
        {
            "key": "group_id",
            "value": "YOUR_GROUP_UUID_HERE",
            "type": "string"
        }
    ],
    "item": [
        {
            "name": "User",
            "item": [
                {
                    "name": "Get Current User",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/users/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        }
                    }
                },
                {
                    "name": "Update User Profile",
                    "request": {
                        "method": "PUT",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"username\": \"John Doe\",\n    \"avatarUrl\": \"https://example.com/avatar.png\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/users/me",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "users",
                                "me"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Groups",
            "item": [
                {
                    "name": "Get All Groups",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/groups",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups"
                            ]
                        }
                    }
                },
                {
                    "name": "Create Group",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"name\": \"Weekend Trip\",\n    \"description\": \"Photos from our weekend getaway!\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/groups",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups"
                            ]
                        }
                    }
                },
                {
                    "name": "Join Group",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"joinCode\": \"ABCDEF\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/groups/join",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "join"
                            ]
                        }
                    }
                },
                {
                    "name": "Get Group Details",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/groups/{{group_id}}",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "{{group_id}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Photos",
            "item": [
                {
                    "name": "Get Group Photos",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/groups/{{group_id}}/photos",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "{{group_id}}",
                                "photos"
                            ]
                        }
                    }
                },
                {
                    "name": "Upload Photo",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "body": {
                            "mode": "formdata",
                            "formdata": [
                                {
                                    "key": "image",
                                    "type": "file",
                                    "src": ""
                                }
                            ]
                        },
                        "url": {
                            "raw": "{{base_url}}/api/groups/{{group_id}}/photos/upload",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "{{group_id}}",
                                "photos",
                                "upload"
                            ]
                        }
                    }
                },
                {
                    "name": "Like Photo",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/groups/{{group_id}}/photos/<PHOTO_ID>/like",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "{{group_id}}",
                                "photos",
                                "<PHOTO_ID>",
                                "like"
                            ]
                        }
                    }
                },
                {
                    "name": "Unlike Photo",
                    "request": {
                        "method": "DELETE",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            }
                        ],
                        "url": {
                            "raw": "{{base_url}}/api/groups/{{group_id}}/photos/<PHOTO_ID>/like",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "groups",
                                "{{group_id}}",
                                "photos",
                                "<PHOTO_ID>",
                                "like"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Feedback",
            "item": [
                {
                    "name": "Submit Feedback",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Authorization",
                                "value": "Bearer {{auth_token}}"
                            },
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n    \"content\": \"Great app! Really enjoying it.\",\n    \"rating\": \"5\"\n}"
                        },
                        "url": {
                            "raw": "{{base_url}}/api/feedback",
                            "host": [
                                "{{base_url}}"
                            ],
                            "path": [
                                "api",
                                "feedback"
                            ]
                        }
                    }
                }
            ]
        }
    ]
}